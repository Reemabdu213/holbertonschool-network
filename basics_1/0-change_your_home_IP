#!/usr/bin/env bash
# Configures /etc/hosts so localhost resolves to 127.0.0.2 and facebook.com resolves to 8.8.8.8

# Update or add localhost entry
if grep -q "^127\.0\.0\.1\s*localhost" /etc/hosts; then
    sed -i 's/^127\.0\.0\.1\s*localhost/127.0.0.2\tlocalhost/' /etc/hosts
else
    echo "127.0.0.2	localhost" >> /etc/hosts
fi

# Update or add facebook.com entry
if grep -q "facebook\.com" /etc/hosts; then
    sed -i 's/^.*facebook\.com.*/8.8.8.8\tfacebook.com/' /etc/hosts
else
    echo "8.8.8.8	facebook.com" >> /etc/hosts
fi
